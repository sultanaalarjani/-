# ===== إعدادات تسجيل الدخول والأمان =====

# رقم جوال مدير الإدارة الأول (المدير العام). يُنشأ تلقائيًا عند أول تشغيل.
# سجّل الدخول بهذا الرقم أول مرة ثم أضف بقية المدراء من اللوحة.
ADMIN_PHONE=0500000000

# اسم مدير الإدارة الأول (اختياري)
ADMIN_NAME=مدير إدارة عمليات الأداء

# اجعلها true فقط إذا كان الموقع يعمل عبر HTTPS.
# للتشغيل الداخلي عبر HTTP اتركها false وإلا لن يعمل تسجيل الدخول.
COOKIE_SECURE=false

# ===== إعدادات إرسال رمز الدخول عبر SMS =====
# اترك SMS_PROVIDER فارغًا لوضع التجربة (الرمز يظهر على الشاشة وفي السجل).
#
# مزوّد عام (أغلب المزوّدات السعودية): SMS_PROVIDER=generic
#   SMS_API_URL=رابط واجهة الإرسال لدى المزوّد
#   SMS_API_KEY=مفتاح الـ API
#   SMS_SENDER=اسم المُرسِل المعتمد
#
# أو Twilio: SMS_PROVIDER=twilio
#   TWILIO_SID=...
#   TWILIO_TOKEN=...
#   TWILIO_FROM=+1XXXXXXXXXX
SMS_PROVIDER=
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER=
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
