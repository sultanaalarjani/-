# ===== إعدادات تسجيل الدخول والأمان =====

# إيميل مدير الإدارة الأول (المدير العام). يُنشأ تلقائيًا عند أول تشغيل.
# سجّل الدخول بهذا الإيميل أول مرة ثم أضف بقية المدراء من اللوحة.
ADMIN_EMAIL=admin@example.com

# اسم مدير الإدارة الأول (اختياري)
ADMIN_NAME=مدير الإدارة

# مفتاح سري لتوقيع جلسات الدخول (غيّره لأي نص طويل عشوائي)
SESSION_SECRET=change-me-to-a-long-random-string

# اجعلها true فقط إذا كان الموقع يعمل عبر HTTPS.
# للتشغيل الداخلي عبر HTTP اتركها false وإلا لن يعمل تسجيل الدخول.
COOKIE_SECURE=false

# ===== إعدادات إرسال الإيميل (SMTP) =====
# لو تركتها فاضية، رمز الدخول بيظهر في شاشة الـ Terminal (وضع التجربة)
# لإرسال إيميل حقيقي عبّئ بيانات بريد الدوام (مثال Gmail / Outlook / سيرفر الشركة)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
